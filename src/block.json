{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "mla/featured-resource",
  "title": "Featured Resource",
  "category": "widgets",
  "icon": "welcome-write-blog",
  "description": "Displays a featured editorial resource with a title and CTA.",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "url": {
      "type": "string",
      "default": ""
    },
    "label": {
      "type": "string",
      "default": "Read more"
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
